# === Base de datos ===
DB_USER=avicola_user
DB_PASSWORD=avicola_pass
DB_NAME=supermercado_avicola
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://avicola_user:avicola_pass@db:5432/supermercado_avicola

# === Backend ===
ENVIRONMENT=development
BACKEND_PORT=8000
SECRET_KEY=local-demo-secret-key-change-before-production-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
AUTO_CREATE_TABLES=true
SEED_DEMO_DATA=true
FRONTEND_DIR=

# === Admin inicial ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_EMAIL=admin@avicola.local
